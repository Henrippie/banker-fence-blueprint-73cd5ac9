{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/:slug", "destination": "/landings/:slug.html" }
  ],

  "redirects": [
    { "source": "/", "destination": "/cerca-eletrica", "permanent": false }
  ],

  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
